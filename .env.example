# Vercel/frontend demo auth only. These are safe to configure in Vercel.
VITE_DEMO_USER=User
VITE_DEMO_PASSWORD=BigData
VITE_DEMO_CREDENTIALS=User:BigData

# Local/offline data gathering only. Do not configure these in Vercel frontend env.
GOOGLE_PLACES_API_KEY=
SERPAPI_KEY=

# Optional quota controls for local gather runs.
GATHER_LIMIT=10
GATHER_RADIUS=5000
GATHER_CONCURRENCY=2
GOOGLE_PLACES_MAX_RESULTS=10
SERPAPI_MAX_RESULTS=10
SERPAPI_TYPES=services
